    schema:addressLocality "Kitchener";
    schema:addressRegion "ON"
  ];
  schema:alternateName "CITS";
  schema:identifier "Q136663001";
  schema:legalName "Centre In The Square Inc."@en;
  schema:location [
    a schema:Role;
    schema:location [
      a schema:Place;
      schema:identifier "Q5062273";
      schema:name "Centre In The Square"
    ];
