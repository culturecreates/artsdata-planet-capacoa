  schema:identifier "Q4851638";
  schema:legalName "Ballet Jörgen Canada"@en;
  schema:name "Ballet Jörgen Canada"@en,
    "Ballet Jörgen du Canada"@fr,
    "Ballet Jörgen Canada";
  schema:url <https://www.jorgendance.ca/>;
  <http://www.ebu.ch/metadata/ontologies/ebucore/ebucore#hasAgentBiography> "Jörgen Dance has brought the joy of dance to communities across Canada. From world-class performances to inclusive training and outreach, we make dance accessible to all. Join us—experience, learn, and connect through Dance for All."@en,
    "Jörgen Dance partage la joie de la danse à travers le Canada. De spectacles de calibre mondial à des programmes inclusifs, nous rendons la danse accessible à tous. Joignez-vous à nous pour vivre, apprendre et partager la Danse pour tous."@fr .

