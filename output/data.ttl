  schema:address [
    a schema:PostalAddress;
    schema:addressCountry "CA";
    schema:addressLocality "Annapolis Royal";
    schema:addressRegion "NS"
  ];
  schema:identifier "King's Theatre Society";
  schema:legalName "Kings Theatre Society"@en;
  schema:location [
    a schema:Role;
    schema:location [
      a schema:Place;
      schema:name "King's Theatre"
    ];
    schema:roleName "Manager/Operator"
  ];
  schema:name "King's Theatre"@en,
    "King's Theatre";
  schema:url <https://www.kingstheatre.ca/>, [
    a schema:Role;
    schema:roleName "Events Webpage";
    schema:url <https://www.kingstheatre.ca/upcoming-events/>
  ];
  <http://www.ebu.ch/metadata/ontologies/ebucore/ebucore#hasAgentBiography> "King’s Theatre, has been operated continously as a both a performing arts hub and cinema for over 100 years.The 220-seat gathering space, located at the heart of Annapolis Royal, presents live performances year-round in all genres, including music, theatre, dance, comedy, spoken word, and more. On screen there’s every kind of cinema, including stage-to-screen works of theatre, opera and ballet. With more than 200 events a year, the aim is to ensure that everyone there is something for everyone. We work with community groups and organizations to provide a venue that is shaped by and for the community. King’s Theatre is also an education and outreach organization, delivering programming for school groups, as well as outreach throughout the community.  King’s has a mandate to ensure that barriers are removed and doors are opened so that everyone in the community feels welcome. King’s offers state-of-the-art stage lighting, sound, and cinematic projection. We value diversity, equity, justice and inclusion, as well as excellence, tradition and innovation."@en;
  wikidata_property:\/P8860 "118981901" .

